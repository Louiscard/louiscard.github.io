#!name=Louis 自定义规则
#!desc=精简版: Gmail/GitHub 强制走代理 + 公共WiFi强制门户修复。已移除 Claude(交给 profile 的 AI 组)/即刻/ChinaMax。
#!category=自定义

[Rule]
# ===== Gmail 强制走代理(直连会被 GFW 掐断 TLS, 邮件发不出)=====
DOMAIN-SUFFIX,gmail.com,Proxies
DOMAIN-SUFFIX,googlemail.com,Proxies

# ===== GitHub 强制走代理(直连 GeoDNS 发美国 IP 时超时, git push 时好时坏, 改走代理求稳)=====
DOMAIN-SUFFIX,github.com,Proxies
DOMAIN-SUFFIX,githubusercontent.com,Proxies
DOMAIN-SUFFIX,githubassets.com,Proxies
DOMAIN-SUFFIX,github.io,Proxies

[Host]
# 公共WiFi强制门户: 探测域名走系统DNS, 否则认证前 DoH 连不上、门户登录页打不开
captive.apple.com = server:syslib